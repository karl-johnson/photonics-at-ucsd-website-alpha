---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="About Photonics Society at UC San Diego.">
  <div class="about-page">

    <header class="about-header">
      <p class="eyebrow">Who we are</p>
      <h1>Photonics Society at UC San Diego</h1>
    </header>

    <div class="about-body">
      <div class="about-main">
        <section class="section">
          <h2>Our mission: to grow the community of optics & photonics at UCSD and to use the appealing & exciting nature of light for broader STEM outreach.</h2>
          <p>
            
			
			Over our history we have designed and built numerous light sciences-related demos and activities. Now, we're documenting and open-sourcing the best ones so that any school, club, or outreach group can replicate them.
          </p>
        </section>

        <section class="section">
          <h2>How to use this site</h2>
          <p>
            The Projects page lets you explore our library visually. Use the scatter plot to compare projects across parameters like budget, complexity, and portability — then click any point (or card) to read about that specific project and access its full build documentation.
          </p>
          <p>
            Each project page links to a Google Doc or PDF with build instructions and other information.
          </p>
        </section>
      </div>

      <aside class="about-sidebar">
        <div class="info-card">
          <div class="info-stat">
            <span class="stat-number">6</span>
            <span class="stat-label">Projects published</span>
          </div>
          <div class="info-stat">
            <span class="stat-number">6</span>
            <span class="stat-label">Parameters per project</span>
          </div>
          <div class="info-stat">
            <span class="stat-number">∞</span>
            <span class="stat-label">Free to use &amp; modify</span>
          </div>
        </div>
        <div class="license-note">
          <span class="mono-label">License</span>
          <p>Project documentation is released under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>. Hardware designs under <a href="https://cern-ohl.web.cern.ch/" target="_blank" rel="noopener">CERN-OHL-S</a>. Website source under MIT.</p>
        </div>
      </aside>
    </div>

  </div>
</BaseLayout>

<style>
.about-page { max-width: 1100px; margin: 0 auto; padding: 3.5rem 2rem 5rem; }

.about-header { max-width: 620px; margin-bottom: 3rem; }
.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--laser-red);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 0.7rem;
}
.about-header h1 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.2;
}

.about-body {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: 2.5rem;
  align-items: start;
}
@media (max-width: 720px) {
  .about-body { grid-template-columns: 1fr; }
}

.about-main { display: flex; flex-direction: column; gap: 2.25rem; }

.section h2 {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--blue);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.75rem;
}
.section p {
  color: var(--text-muted);
  line-height: 1.75;
  font-size: 0.95rem;
  margin-bottom: 0.75rem;
}
.section p:last-child { margin-bottom: 0; }

.github-link {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text);
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.5rem 1rem;
  border-radius: 7px;
  margin-top: 0.5rem;
  transition: border-color 0.15s, color 0.15s;
}
.github-link:hover { border-color: var(--laser-red); color: var(--blue); }

/* Sidebar */
.about-sidebar { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 72px; }

.info-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem;
  display: flex; flex-direction: column; gap: 1.25rem;
}
.info-stat { display: flex; flex-direction: column; gap: 0.2rem; }
.stat-number {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 700;
  color: var(--laser-red);
  letter-spacing: -0.04em;
  line-height: 1;
}
.stat-label {
  font-size: 0.78rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.license-note {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.25rem;
}
.mono-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--laser-red);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.5rem;
}
.license-note p { font-size: 0.78rem; color: var(--text-muted); line-height: 1.6; }
.license-note a { color: var(--blue); text-decoration: underline; text-underline-offset: 2px; }
.license-note a:hover { color: var(--laser-red); }
</style>
