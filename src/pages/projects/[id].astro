---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';
import parameters from '../../data/parameters.json';

export function getStaticPaths() {
  return projects.map(p => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
---
<BaseLayout title={project.title} description={project.tagline}>
  <div class="project-page">

    <div class="back-row">
      <a href="/" class="back-link">← All Projects</a>
    </div>

    <header class="project-header">
      <p class="eyebrow">Open-Source Optics Project</p>
      <h1>{project.title}</h1>
      <p class="tagline">{project.tagline}</p>
      <div class="header-tags">
        {project.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <div class="project-layout">
      <!-- Main content -->
      <div class="project-main">
        <!-- Image placeholder -->
        <div class="image-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v4M12 18v4M2 12h4M18 12h4"/>
            <path d="M5.64 5.64l2.83 2.83M15.53 15.53l2.83 2.83M5.64 18.36l2.83-2.83M15.53 8.47l2.83-2.83" opacity="0.4"/>
          </svg>
          <p>Project images will appear here</p>
        </div>

        <!-- Description -->
        <section class="section">
          <h2>About this project</h2>
          <p>{project.description}</p>
        </section>

        <!-- CTA -->
        <a href={project.docsUrl} target="_blank" rel="noopener" class="docs-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          View Full Build Plans
          <span class="link-arrow">↗</span>
        </a>
      </div>

      <!-- Sidebar: parameters -->
      <aside class="project-sidebar">
        <div class="param-card">
          <h3>Project Parameters</h3>
          <div class="params-list">
            {Object.entries(project.parameters).map(([key, val]) => {
              const param = parameters.find(p => p.key === key);
              const pct = (val / 10) * 100;
              return (
                <div class="param-row">
                  <div class="param-meta">
                    <span class="param-name">{param?.label ?? key}</span>
                    <span class="param-score">{val}<span class="param-max">/10</span></span>
                  </div>
                  <div class="param-track">
                    <div class="param-fill" style={`width: ${pct}%`}></div>
                  </div>
                  {param && <p class="param-desc">{param.description}</p>}
                </div>
              );
            })}
          </div>
        </div>
      </aside>
    </div>

  </div>
</BaseLayout>

<style>
.project-page { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 5rem; }

.back-row { margin-bottom: 1.5rem; }
.back-link {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-muted);
  transition: color 0.15s;
}
.back-link:hover { color: var(--blue); }

.project-header { margin-bottom: 2.5rem; max-width: 680px; }
.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--violet);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 0.6rem;
}
.project-header h1 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin-bottom: 0.7rem;
}
.tagline { font-size: 1.05rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1rem; }
.header-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.tag {
  font-size: 0.72rem;
  font-family: var(--font-mono);
  padding: 0.2rem 0.55rem;
  border-radius: 4px;
  background: rgba(124,106,247,0.1);
  color: var(--violet);
  border: 1px solid rgba(124,106,247,0.2);
}

.project-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 2rem;
  align-items: start;
}
@media (max-width: 780px) {
  .project-layout { grid-template-columns: 1fr; }
}

.project-main { display: flex; flex-direction: column; gap: 1.75rem; }

.image-placeholder {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  height: 300px;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem;
  color: var(--border);
}
.image-placeholder svg { color: var(--text-muted); opacity: 0.3; }
.image-placeholder p { font-size: 0.8rem; font-family: var(--font-mono); color: var(--text-muted); opacity: 0.5; }

.section h2 {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 600;
  color: var(--blue);
  margin-bottom: 0.65rem;
  letter-spacing: -0.01em;
}
.section p {
  color: var(--text-muted);
  line-height: 1.7;
  font-size: 0.95rem;
}

.docs-link {
  display: inline-flex; align-items: center; gap: 0.6rem;
  background: var(--violet);
  color: #fff;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 0.9rem;
  padding: 0.7rem 1.3rem;
  border-radius: 8px;
  transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  align-self: flex-start;
  box-shadow: 0 0 20px rgba(124,106,247,0.3);
}
.docs-link:hover {
  background: #6a58e0;
  transform: translateY(-1px);
  box-shadow: 0 4px 24px rgba(124,106,247,0.45);
}
.link-arrow { margin-left: auto; }

/* Sidebar */
.param-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem;
  position: sticky; top: 72px;
}
.param-card h3 {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 1.1rem;
}
.params-list { display: flex; flex-direction: column; gap: 1rem; }
.param-row { display: flex; flex-direction: column; gap: 0.3rem; }
.param-meta { display: flex; justify-content: space-between; align-items: baseline; }
.param-name { font-family: var(--font-display); font-size: 0.82rem; font-weight: 500; }
.param-score { font-family: var(--font-mono); font-size: 0.9rem; color: var(--blue); font-weight: 500; }
.param-max { color: var(--text-muted); font-size: 0.7rem; }
.param-track { height: 4px; background: var(--surface-2); border-radius: 2px; overflow: hidden; }
.param-fill { height: 100%; background: linear-gradient(90deg, var(--violet), var(--blue)); border-radius: 2px; }
.param-desc { font-size: 0.72rem; color: var(--text-muted); font-family: var(--font-mono); line-height: 1.4; }
</style>
